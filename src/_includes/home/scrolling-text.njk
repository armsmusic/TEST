{# ================================================================
   SCROLLING-TEXT — marquee de texto con gradiente, loop infinito
   Impact style. Requiere: arms.css (.scrolling-text*, .text-gradient)
   y el Web Component <marquee-text> en arms-home.js
================================================================= #}

<div class="section section--tight">
  <div class="scrolling-text scrolling-text--auto">
    <marquee-text scrolling-speed="5" class="scrolling-text__wrapper">
      <span class="scrolling-text__text heading">
        <span class="text-gradient" style="--gradient: linear-gradient(90deg, rgba(77, 82, 60, 1), rgba(133, 141, 103, 1) 100%)">Audio de Alta Fidelidad sin Gastar de más</span>
      </span>
      <span class="scrolling-text__text heading motion-reduce:hidden" aria-hidden="true">
        <span class="text-gradient" style="--gradient: linear-gradient(90deg, rgba(77, 82, 60, 1), rgba(133, 141, 103, 1) 100%)">Audio de Alta Fidelidad sin Gastar de más</span>
      </span>
      <span class="scrolling-text__text heading motion-reduce:hidden" aria-hidden="true">
        <span class="text-gradient" style="--gradient: linear-gradient(90deg, rgba(77, 82, 60, 1), rgba(133, 141, 103, 1) 100%)">Audio de Alta Fidelidad sin Gastar de más</span>
      </span>
      <span class="scrolling-text__text heading motion-reduce:hidden" aria-hidden="true">
        <span class="text-gradient" style="--gradient: linear-gradient(90deg, rgba(77, 82, 60, 1), rgba(133, 141, 103, 1) 100%)">Audio de Alta Fidelidad sin Gastar de más</span>
      </span>
    </marquee-text>
  </div>
</div>
