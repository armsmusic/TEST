{# ===============================================================
   ARMS Music — nav-drawer.njk
   Menú lateral de navegación (hamburguesa). Extraído de base.njk
   sin modificar contenido/comportamiento — solo modularización.
================================================================ #}

<div id="menu-nav-overlay" onclick="cerrarMenuNav()" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:1999; backdrop-filter:blur(2px);"></div>

<div id="menu-nav-drawer" aria-label="Menú de navegación" style="position:fixed; top:0; left:0; height:100%; width:82%; max-width:320px; background:#111111; z-index:2000; transform:translateX(-100%); transition:transform .3s cubic-bezier(0.4,0,0.2,1), box-shadow .3s ease; display:flex; flex-direction:column; border-right:1px solid rgba(255,255,255,0.08); box-shadow:none;">

  <!-- Header -->
  <div style="padding:1.25rem 1.25rem 1rem; border-bottom:1px solid rgba(255,255,255,0.08); display:flex; align-items:center; justify-content:space-between;">
    <a href="/" onclick="cerrarMenuNav()" aria-label="ARMS Music">
      <img src="/logo-navbar.svg" alt="ARMS Music" height="36" style="display:block;" />
    </a>
    <button onclick="cerrarMenuNav()" aria-label="Cerrar menú" style="background:none; border:none; color:rgba(255,255,255,0.5); font-size:1.4rem; cursor:pointer; padding:0.25rem; line-height:1; display:flex; align-items:center; justify-content:center;">&times;</button>
  </div>

  <!-- Items -->
  <nav style="flex:1; overflow-y:auto; padding:0.5rem 0;">

    <a href="/in-ears/" onclick="cerrarMenuNav()" style="display:flex; align-items:center; justify-content:space-between; padding:1rem 1.25rem; color:#fff; text-decoration:none; font-size:0.9rem; font-weight:600; letter-spacing:0.04em; text-transform:uppercase; border-bottom:1px solid rgba(255,255,255,0.06); transition:background .15s ease;"
      onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='transparent'">
      In-Ears
    </a>

    <a href="/in-ears/accesorios/" onclick="cerrarMenuNav()" style="display:flex; align-items:center; justify-content:space-between; padding:1rem 1.25rem; color:#fff; text-decoration:none; font-size:0.9rem; font-weight:600; letter-spacing:0.04em; text-transform:uppercase; border-bottom:1px solid rgba(255,255,255,0.06); transition:background .15s ease;"
      onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='transparent'">
      Accesorios
    </a>

    <a href="/audio/sistemas/" onclick="cerrarMenuNav()" style="display:flex; align-items:center; justify-content:space-between; padding:1rem 1.25rem; color:#fff; text-decoration:none; font-size:0.9rem; font-weight:600; letter-spacing:0.04em; text-transform:uppercase; border-bottom:1px solid rgba(255,255,255,0.06); transition:background .15s ease;"
      onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='transparent'">
      Monitoreo
    </a>

    <!-- Audio con acordeón -->
    <div>
      <button onclick="toggleAudioSubmenu()" style="width:100%; display:flex; align-items:center; justify-content:space-between; padding:1rem 1.25rem; color:#fff; background:none; border:none; border-bottom:1px solid rgba(255,255,255,0.06); font-size:0.9rem; font-weight:600; letter-spacing:0.04em; text-transform:uppercase; cursor:pointer; transition:background .15s ease;"
        onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='transparent'">
        Audio
        <svg id="audio-submenu-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transition:transform .25s ease; flex-shrink:0;"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
      <div id="audio-submenu" style="display:none; background:rgba(255,255,255,0.03); border-bottom:1px solid rgba(255,255,255,0.06);">
        <a href="/audio/sistemas/" onclick="cerrarMenuNav()" style="display:block; padding:0.75rem 1.25rem 0.75rem 2rem; color:rgba(255,255,255,0.7); text-decoration:none; font-size:0.85rem; font-weight:500; border-bottom:1px solid rgba(255,255,255,0.04); transition:color .15s ease, background .15s ease;"
          onmouseover="this.style.color='#fff';this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.color='rgba(255,255,255,0.7)';this.style.background='transparent'">Sistemas</a>
        <a href="/audio/interfaces/" onclick="cerrarMenuNav()" style="display:block; padding:0.75rem 1.25rem 0.75rem 2rem; color:rgba(255,255,255,0.7); text-decoration:none; font-size:0.85rem; font-weight:500; border-bottom:1px solid rgba(255,255,255,0.04); transition:color .15s ease, background .15s ease;"
          onmouseover="this.style.color='#fff';this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.color='rgba(255,255,255,0.7)';this.style.background='transparent'">Interfaces</a>
        <a href="/audio/microfonos/" onclick="cerrarMenuNav()" style="display:block; padding:0.75rem 1.25rem 0.75rem 2rem; color:rgba(255,255,255,0.7); text-decoration:none; font-size:0.85rem; font-weight:500; border-bottom:1px solid rgba(255,255,255,0.04); transition:color .15s ease, background .15s ease;"
          onmouseover="this.style.color='#fff';this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.color='rgba(255,255,255,0.7)';this.style.background='transparent'">Micrófonos</a>
        <a href="/audio/cables/" onclick="cerrarMenuNav()" style="display:block; padding:0.75rem 1.25rem 0.75rem 2rem; color:rgba(255,255,255,0.7); text-decoration:none; font-size:0.85rem; font-weight:500; transition:color .15s ease, background .15s ease;"
          onmouseover="this.style.color='#fff';this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.color='rgba(255,255,255,0.7)';this.style.background='transparent'">Cables</a>
      </div>
    </div>

  </nav>
</div>
