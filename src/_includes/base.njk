<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
  {% include "seo.njk" %}
  {% include "schema.njk" %}

  <!-- FAVICON -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />

  <!-- FUENTES -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />

  <!-- BOOTSTRAP 5 — DESCONECTADO a partir de la migración a Impact.            -->
  <!-- Las páginas no migradas (checkout, producto, categoría, carrito) dependen -->
  <!-- de Bootstrap y se verán rotas hasta que se migren a arms.css una por una. -->
  <!-- Para reactivarlo temporalmente, descomenta la línea de abajo:            -->
  <!-- <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" /> -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

  <!-- ESTILOS PROPIOS -->
  <!-- main.css — DESCONECTADO. Era el sistema legacy sobre Bootstrap.        -->
  <!-- Páginas no migradas a Impact pueden depender de él. Para reactivarlo:  -->
  <!-- <link rel="stylesheet" href="/assets/css/main.css" /> -->
  <link rel="stylesheet" href="/assets/css/arms.css" />
  <link rel="stylesheet" href="/assets/css/producto.css" />
  <link rel="stylesheet" href="/assets/css/categoria.css" />
</head>

<body>

  {% include "announcement-bar.njk" %}
  {% include "header.njk" %}
  {% include "search-panel.njk" %}

  <!-- ============================================================
       CONTENIDO PRINCIPAL
  ============================================================ -->
  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}
  {% include "floating-ui.njk" %}
  {% include "nav-drawer.njk" %}
  {% include "cart-drawer.njk" %}
  {% include "bottom-nav.njk" %}

  <!-- JS propios — orden importa: announcement → header → slideshow → store → drawer → ui → buscar -->
  <script src="/assets/js/arms-announcement.js" defer></script>
  <script src="/assets/js/arms-header.js" defer></script>
  <script type="module" src="/assets/js/arms-slideshow.js"></script>
  <script src="/assets/js/cart-store.js" defer></script>
  <script src="/assets/js/cart-drawer.js" defer></script>
  <script src="/assets/js/site-ui.js" defer></script>
  <script src="/assets/js/buscar.js" defer></script>

</body>
</html>
