{# ===============================================================
   ARMS Music — header.njk
   Header con comportamiento transparente-sobre-hero / sólido al
   hacer scroll, igual a Impact. Estructura real confirmada:
   height-observer > store-header[sticky][allow-transparency]
   Mantiene las funciones JS existentes (abrirMenuNav, abrirCarrito,
   búsqueda) — solo cambia la estructura visual, no la lógica.
================================================================ #}

<height-observer variable="header">
  <store-header class="header" sticky allow-transparency>
    <div class="header__wrapper">

      <div class="header__main-nav">
        <div class="header__icon-list">
          <!-- Hamburguesa mobile -->
          <button class="tap-area header__icon-button" onclick="abrirMenuNav()" aria-label="Abrir menú">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
        </div>

        <!-- Nav desktop -->
        <nav class="header__link-list">
          <ul class="contents">
            <li>
              <a href="/in-ears/" class="header__link">In-Ears</a>
            </li>
            <li>
              <a href="/in-ears/accesorios/" class="header__link">Accesorios</a>
            </li>
            <li>
              <a href="/audio/sistemas/" class="header__link">Monitoreo</a>
            </li>
            <li class="header__link-list-item--dropdown">
              <button class="header__link header__link--dropdown" onclick="toggleAudioDropdown()" aria-label="Audio">
                Audio
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div id="audio-dropdown" class="header__dropdown">
                <a href="/audio/sistemas/" class="header__dropdown-link">Sistemas</a>
                <a href="/audio/interfaces/" class="header__dropdown-link">Interfaces</a>
                <a href="/audio/microfonos/" class="header__dropdown-link">Micrófonos</a>
                <a href="/audio/cables/" class="header__dropdown-link">Cables</a>
              </div>
            </li>
          </ul>
        </nav>
      </div>

      <!-- Logo centrado/izquierda según breakpoint -->
      <h1 class="header__logo">
        <a href="/" aria-label="ARMS Music">
          <span class="sr-only">ARMS Music</span>
          <img class="header__logo-image" src="/logo-navbar.svg" alt="" width="90" height="20">
          <img class="header__logo-image header__logo-image--transparent" src="/logo-navbar-light.svg" alt="" width="90" height="20">
        </a>
      </h1>

      <!-- Búsqueda + Carrito + WhatsApp -->
      <div class="header__icon-list header__icon-list--secondary">
        <div class="navbar-search-wrap" id="navbar-search-wrap-desktop">
          <button id="navbar-search-btn" class="tap-area header__icon-button" aria-label="Buscar productos">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
        </div>

        <a href="https://wa.me/50234646667" target="_blank" rel="noopener" class="tap-area header__icon-button" aria-label="WhatsApp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 6.32A8.86 8.86 0 0 0 12.05 4a8.94 8.94 0 0 0-7.74 13.4L3 21l3.7-1.28a8.9 8.9 0 0 0 4.36 1.13h.01a8.94 8.94 0 0 0 8.93-8.94 8.86 8.86 0 0 0-2.4-5.59zm-5.55 13.7a7.4 7.4 0 0 1-3.78-1.04l-.27-.16-2.8.97.94-2.71-.18-.28a7.44 7.44 0 0 1 6.1-11.46 7.36 7.36 0 0 1 5.24 2.18 7.36 7.36 0 0 1 2.17 5.25 7.45 7.45 0 0 1-7.42 7.25z"/></svg>
        </a>

        <button onclick="abrirCarrito()" class="tap-area header__icon-button header__cart-button" aria-label="Ver carrito">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          <span id="cart-count-desktop" class="header__cart-count">0</span>
        </button>
      </div>

    </div>
  </store-header>
</height-observer>
