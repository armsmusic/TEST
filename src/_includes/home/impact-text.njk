{# ================================================================
   IMPACT-TEXT — nombre de producto en texto gigante + descripción
   Impact style. Producto destacado: KZ Terminator ZSX (id: kz-terminator-zsx)
   Requiere: arms.css (.impact-text*, .text-gradient, .button--xl)
================================================================= #}

<div class="section">
  <style>
  #impact-text-zsx {
    --impact-text-font-size: min(28vw, 110px);
  }

  @media screen and (min-width: 700px) {
    #impact-text-zsx {
      --impact-text-font-size: min(18vw, 220px);
    }
  }
</style>

  <div class="impact-text impact-text--center" id="impact-text-zsx">
    <div class="snap-center">
      <h2 class="impact-text__text heading break-all">
        <impact-text reveal-js>
          <span class="text-gradient" style="--gradient: linear-gradient(180deg, rgba(26, 26, 26, 0.2), rgba(26, 26, 26, 0) 100%)">ZSX</span>
        </impact-text>
      </h2>
      <div class="impact-text__content">
        <div class="prose">
          <h3 class="h4">El monitor que rompió el mercado</h3>
          <p>Configuración híbrida de 12 drivers — 1 dinámico de doble imán más 5 armaduras balanceadas por lado — para graves con pegada, medios definidos y agudos vibrantes sin sibilancias. Placa frontal de aleación de zinc.</p>
          <a class="button button--xl" href="{{ 'kz-terminator-zsx' | productoUrl }}">Ver KZ Terminator ZSX</a>
        </div>
      </div>
    </div>
  </div>
</div>
