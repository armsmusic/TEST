{# ================================================================
   TIMELINE — historia de marca por hitos, navegación por año
   Reutiliza <effect-carousel> y <page-dots>, ya registrados en
   arms-slideshow.js (hero) — no necesita ningún Web Component nuevo.
   Requiere: arms.css (.timeline*, .relative)

   ⚠️ TODO — PLACEHOLDERS: los 3 hitos de abajo son de relleno
   temporal (años y descripciones genéricas). Reemplázalos con la
   historia real de ARMS Music cuando la tengas. Busca "TODO: hito
   real" en cada bloque.

   Imágenes: src/assets/img/home/timeline-1.jpg, timeline-2.jpg,
   timeline-3.jpg (pendientes de subir — 1500x1500px aprox).
================================================================= #}

<div class="section section-blends section-full">
  <div class="timeline" style="--timeline-nav-item-count: 3;">

    <effect-carousel class="timeline__slider" id="timeline-carousel-armsmusic">

      {# TODO: hito real — año, foto y descripción del primer hito #}
      <div class="timeline__slide">
        <div class="timeline__image-wrapper">
          <img src="/assets/img/home/timeline-1.jpg" alt="" width="1500" height="1500" loading="lazy" class="timeline__image rounded" sizes="(max-width: 700px) 100vw, min(700px, 50vw)">
        </div>
        <div class="prose">
          <p class="subheading text-base">Nuestra historia</p>
          <p class="h2">ARMS Music nace con la idea de traer audio KZ de calidad a Guatemala, sin intermediarios ni sobreprecios.</p>
        </div>
      </div>

      {# TODO: hito real — año, foto y descripción del segundo hito #}
      <div class="timeline__slide reveal-invisible">
        <div class="timeline__image-wrapper">
          <img src="/assets/img/home/timeline-2.jpg" alt="" width="1500" height="1500" loading="lazy" class="timeline__image rounded" sizes="(max-width: 700px) 100vw, min(700px, 50vw)">
        </div>
        <div class="prose">
          <p class="subheading text-base">Crecimiento</p>
          <p class="h2">Ampliamos el catálogo con cables, interfaces y micrófonos para cubrir todo lo que un músico necesita.</p>
        </div>
      </div>

      {# TODO: hito real — año, foto y descripción del tercer hito #}
      <div class="timeline__slide reveal-invisible">
        <div class="timeline__image-wrapper">
          <img src="/assets/img/home/timeline-3.jpg" alt="" width="1500" height="1500" loading="lazy" class="timeline__image rounded" sizes="(max-width: 700px) 100vw, min(700px, 50vw)">
        </div>
        <div class="prose">
          <p class="subheading text-base">Hoy</p>
          <p class="h2">Seguimos creciendo, con envíos a toda Guatemala y atención directa por WhatsApp en cada compra.</p>
        </div>
      </div>

    </effect-carousel>

    <div class="timeline__controls scroll-area bleed md:unbleed">
      <div class="relative w-full">
        <span class="timeline__nav-bar"></span>
        <page-dots align-selected=".timeline__controls" class="timeline__nav" aria-controls="timeline-carousel-armsmusic">
          <button class="timeline__nav-item" type="button" aria-current="true">
            <span class="sr-only">Ir al hito 1</span>
            <span class="timeline__nav-label text-sm bold">Inicio</span>
          </button>
          <button class="timeline__nav-item" type="button" aria-current="false">
            <span class="sr-only">Ir al hito 2</span>
            <span class="timeline__nav-label text-sm bold">Crecimiento</span>
          </button>
          <button class="timeline__nav-item" type="button" aria-current="false">
            <span class="sr-only">Ir al hito 3</span>
            <span class="timeline__nav-label text-sm bold">Hoy</span>
          </button>
        </page-dots>
      </div>

      <div aria-controls="timeline-carousel-armsmusic" class="timeline__buttons md-max:hidden">
        <button is="prev-button" class="circle-button ring group" aria-controls="timeline-carousel-armsmusic">
          <span class="sr-only">Anterior</span>
          <span class="animated-arrow animated-arrow--reverse"></span>
        </button>

        <button is="next-button" class="circle-button ring group" aria-controls="timeline-carousel-armsmusic">
          <span class="sr-only">Siguiente</span>
          <span class="animated-arrow"></span>
        </button>
      </div>
    </div>

  </div>
</div>
