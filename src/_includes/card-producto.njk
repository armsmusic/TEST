{# ================================================================
   card-producto.njk — TARJETA de producto de catálogo (pilar/subpilar
   y "relacionados"). RESKIN visual al product-card de Impact.

   ⚠️ FUNCIONAMIENTO INTACTO: no se tocó ninguna lógica, binding,
   id, handler ni filtro. Solo cambiaron las CLASES visuales de
   card-categoria-* → product-card* (que ya viven en arms.css desde
   la migración de "Más Vendidos"). Datos vía objeto `prod`, URL vía
   `prodUrl`, variantes vía `vs[]`/`varId`, botón vía `btnId` +
   agregarAlCarrito()/seleccionarVariante(). Precio con filtro gtq.

   Estructura Impact: <article.product-card> (no <product-card> custom
   element, para no depender de un Web Component sin registrar) con
   fondo blanco (--background: 255 255 255) como Impact.
   Hover-swap condicional en product-img.njk (si hay 2ª imagen).
================================================================ #}

<article data-lazy-card
  class="product-card product-card--show-secondary-media bg-custom text-custom card-categoria"
  style="--background: 255 255 255; --text-color: 26 26 26;">

  {% if prod.descuento %}
  <div class="product-card__badge-list">
    <span class="badge badge--on-sale">{{ prod.descuento }}</span>
  </div>
  {% endif %}

  <div class="product-card__figure">
    <a href="{{ prodUrl }}" aria-label="{{ prod.nombre }}">
      {% include "product-img.njk" %}
    </a>
  </div>

  <div class="product-card__info">
    <div class="v-stack gap-2 w-full arms-card-body card-categoria-body">

      <span class="product-card__title">
        <a href="{{ prodUrl }}" class="bold card-categoria-nombre">{{ prod.nombre }}{% if prod.subtitulo %}<small class="product-card__subtitle">{{ prod.subtitulo }}</small>{% endif %}</a>
      </span>

      <price-list class="price-list">
        {% if prod.precioOriginal %}<s class="text-subdued card-cat-precio-original">{{ prod.precioOriginal | gtq }}</s>{% endif %}
        <span class="{% if prod.precioOriginal %}text-on-sale{% endif %} card-cat-precio-actual">{{ prod.precio | gtq }}</span>
      </price-list>

      {% if prod.variantes %}
      <div class="arms-card-variantes" id="{{ varId }}">
        {% for varName in prod.variantes %}
        <button onclick="seleccionarVariante(this, '{{ prod.nombre }}', '{{ varName }}', {{ prod.precio }})"
          data-img="/assets/img/productos/{{ prod.imagenesVariantes[varName] if prod.imagenesVariantes[varName] else prod.imagenes[0] }}"
          class="arms-var-btn{% if loop.first %} var-btn-active{% endif %}"
          style="{{ vs[varName] }};{% if loop.first %} border-width:2px;{% endif %}">{{ varName }}</button>
        {% endfor %}
      </div>
      {% endif %}

      <div class="stock-indicator arms-card-stock"></div>

      {% if prod.variantes %}
      <button class="button btn-cat-agregar btn-agregar"
        id="{{ btnId }}"
        data-product-name="{{ prod.nombre }} - {{ prod.variantes[0] }}"
        data-img="/assets/img/productos/{{ prod.imagenesVariantes[prod.variantes[0]] if prod.imagenesVariantes[prod.variantes[0]] else prod.imagenes[0] }}"
        onclick="agregarAlCarrito('{{ prod.nombre }} - {{ prod.variantes[0] }}', {{ prod.precio }}, this)">
        <i class="fa-solid fa-cart-plus"></i> Agregar
      </button>
      {% else %}
      <button class="button btn-cat-agregar btn-agregar"
        data-product-name="{{ prod.nombre }}"
        data-img="/assets/img/productos/{{ prod.imagenes[0] }}"
        onclick="agregarAlCarrito('{{ prod.nombre }}', {{ prod.precio }}, this)">
        <i class="fa-solid fa-cart-plus"></i> Agregar
      </button>
      {% endif %}

    </div>
  </div>
</article>
