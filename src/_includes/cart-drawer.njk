{# ===============================================================
   ARMS Music — cart-drawer.njk
   Carrito lateral (overlay + drawer). Extraído de base.njk
   sin modificar contenido/comportamiento — solo modularización.
================================================================ #}

<div id="cart-overlay" onclick="cerrarCarrito()" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:2000; backdrop-filter:blur(4px);"></div>

<div id="cart-drawer" aria-label="Carrito de compras" style="position:fixed; top:0; right:0; height:100%; width:82%; max-width:480px; background:#171717; z-index:2001; transform:translateX(100%); transition:transform .3s cubic-bezier(0.4,0,0.2,1), box-shadow .3s ease; display:flex; flex-direction:column; border-left:1px solid rgba(255,255,255,0.08); box-shadow:none;">

  <!-- Pantalla 1: Carrito -->
  <div id="screen-cart" style="display:flex; flex-direction:column; height:100%;">
    <div style="padding:1.5rem; border-bottom:1px solid rgba(255,255,255,0.08); display:flex; align-items:center; justify-content:space-between;">
      <h5 style="margin:0; font-weight:700; color:#fff;">🛒 Tu carrito</h5>
      <button onclick="cerrarCarrito()" style="background:none; border:none; color:rgba(255,255,255,0.5); font-size:1.5rem; cursor:pointer; padding:0; line-height:1;">&times;</button>
    </div>
    <div id="cart-items" style="flex:1; overflow-y:auto; padding:1.25rem;">
      <div id="cart-empty" style="text-align:center; padding:3rem 1rem; color:rgba(255,255,255,0.4);">
        <div style="font-size:3rem; margin-bottom:1rem;">🛒</div>
        <p>Tu carrito está vacío</p>
        <button onclick="cerrarCarrito()" class="btn btn-sm btn-outline-secondary mt-2">Ver productos</button>
      </div>
      <div id="cart-list"></div>
      <div id="cart-stock-msg" style="display:none; margin-top:0.75rem; padding:0.5rem 0.75rem; background:rgba(239,68,68,0.12); border:1px solid rgba(239,68,68,0.25); border-radius:0.5rem; color:#f87171; font-size:0.8rem; font-weight:600; text-align:center;"></div>
    </div>
    <div id="cart-footer" style="display:none; padding:1.25rem; border-top:1px solid rgba(255,255,255,0.08);">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
        <span style="color:rgba(255,255,255,0.6); font-size:0.9rem;">Total</span>
        <span id="cart-total" style="font-size:1.4rem; font-weight:800; color:#fff;">Q0</span>
      </div>
      <button onclick="irACheckout()" class="btn btn-primary w-100" style="border-radius:0.75rem; padding:0.875rem; font-size:1rem;">
        Proceder al pago →
      </button>
    </div>
  </div>

</div>
