{# ================================================================
   TIMELINE — historia de marca por hitos, navegación por año
   Reutiliza <effect-carousel> y <page-dots>, ya registrados en
   arms-slideshow.js (hero) — no necesita ningún Web Component nuevo.
   Requiere: arms.css (.timeline*, .relative)

   ⚠️ TODO — PLACEHOLDERS: los 6 hitos de abajo son de relleno
   temporal (años y descripciones genéricas). Reemplázalos con la
   historia real de ARMS Music cuando la tengas. Busca "TODO: hito
   real" en cada bloque.

   Estructura fiel a Impact: 6 hitos + 6 puntos, nav scrollable
   horizontalmente (se ven ~4 en pantalla, el resto al deslizar el
   nav). --timeline-nav-item-count debe coincidir con el nº de slides.

   Imágenes: src/assets/img/home/timeline/1.webp … 6.webp
================================================================= #}

<div class="section section-blends section-full">
  <div class="timeline" style="--timeline-nav-item-count: 6;">

    <effect-carousel class="timeline__slider" id="timeline-carousel-armsmusic">

      {# TODO: hito real — año, foto y descripción del hito 1 #}
      <div class="timeline__slide">
        <div class="timeline__image-wrapper">
          <img src="/assets/img/home/timeline/1.webp" alt="" width="1500" height="1500" loading="lazy" class="timeline__image arms-rounded" sizes="(max-width: 700px) 100vw, min(700px, 50vw)">
        </div>
        <div class="prose">
          <p class="subheading text-base">Nuestra historia</p>
          <p class="h2">ARMS Music nace con la idea de traer audio KZ de calidad a Guatemala, sin intermediarios ni sobreprecios.</p>
        </div>
      </div>

      {# TODO: hito real — año, foto y descripción del hito 2 #}
      <div class="timeline__slide reveal-invisible">
        <div class="timeline__image-wrapper">
          <img src="/assets/img/home/timeline/2.webp" alt="" width="1500" height="1500" loading="lazy" class="timeline__image arms-rounded" sizes="(max-width: 700px) 100vw, min(700px, 50vw)">
        </div>
        <div class="prose">
          <p class="subheading text-base">Primer catálogo</p>
          <p class="h2">Lanzamos nuestra primera selección de IEMs KZ y QKZ, pensada para quienes buscan gran sonido a precio justo.</p>
        </div>
      </div>

      {# TODO: hito real — año, foto y descripción del hito 3 #}
      <div class="timeline__slide reveal-invisible">
        <div class="timeline__image-wrapper">
          <img src="/assets/img/home/timeline/3.webp" alt="" width="1500" height="1500" loading="lazy" class="timeline__image arms-rounded" sizes="(max-width: 700px) 100vw, min(700px, 50vw)">
        </div>
        <div class="prose">
          <p class="subheading text-base">Expansión</p>
          <p class="h2">Ampliamos el catálogo con cables e interfaces de audio, cubriendo más necesidades de cada músico.</p>
        </div>
      </div>

      {# TODO: hito real — año, foto y descripción del hito 4 #}
      <div class="timeline__slide reveal-invisible">
        <div class="timeline__image-wrapper">
          <img src="/assets/img/home/timeline/4.webp" alt="" width="1500" height="1500" loading="lazy" class="timeline__image arms-rounded" sizes="(max-width: 700px) 100vw, min(700px, 50vw)">
        </div>
        <div class="prose">
          <p class="subheading text-base">Audio profesional</p>
          <p class="h2">Sumamos micrófonos y accesorios profesionales para grabación, streaming y producción en casa.</p>
        </div>
      </div>

      {# TODO: hito real — año, foto y descripción del hito 5 #}
      <div class="timeline__slide reveal-invisible">
        <div class="timeline__image-wrapper">
          <img src="/assets/img/home/timeline/5.webp" alt="" width="1500" height="1500" loading="lazy" class="timeline__image arms-rounded" sizes="(max-width: 700px) 100vw, min(700px, 50vw)">
        </div>
        <div class="prose">
          <p class="subheading text-base">Envíos nacionales</p>
          <p class="h2">Habilitamos envíos a toda Guatemala, llevando audio de calidad a cada rincón del país.</p>
        </div>
      </div>

      {# TODO: hito real — año, foto y descripción del hito 6 #}
      <div class="timeline__slide reveal-invisible">
        <div class="timeline__image-wrapper">
          <img src="/assets/img/home/timeline/6.webp" alt="" width="1500" height="1500" loading="lazy" class="timeline__image arms-rounded" sizes="(max-width: 700px) 100vw, min(700px, 50vw)">
        </div>
        <div class="prose">
          <p class="subheading text-base">Hoy</p>
          <p class="h2">Seguimos creciendo como comunidad, con atención directa por WhatsApp y asesoría en cada compra.</p>
        </div>
      </div>

    </effect-carousel>

    <div class="timeline__controls scroll-area bleed md:unbleed">
      <div class="relative w-full">
        <span class="timeline__nav-bar"></span>
        <page-dots align-selected=".timeline__controls" class="timeline__nav" aria-controls="timeline-carousel-armsmusic">
          <button class="timeline__nav-item" type="button" aria-current="true">
            <span class="sr-only">Ir al hito 1</span>
            <span class="timeline__nav-label text-sm bold">Nuestra historia</span>
          </button>
          <button class="timeline__nav-item" type="button" aria-current="false">
            <span class="sr-only">Ir al hito 2</span>
            <span class="timeline__nav-label text-sm bold">Primer catálogo</span>
          </button>
          <button class="timeline__nav-item" type="button" aria-current="false">
            <span class="sr-only">Ir al hito 3</span>
            <span class="timeline__nav-label text-sm bold">Expansión</span>
          </button>
          <button class="timeline__nav-item" type="button" aria-current="false">
            <span class="sr-only">Ir al hito 4</span>
            <span class="timeline__nav-label text-sm bold">Audio profesional</span>
          </button>
          <button class="timeline__nav-item" type="button" aria-current="false">
            <span class="sr-only">Ir al hito 5</span>
            <span class="timeline__nav-label text-sm bold">Envíos nacionales</span>
          </button>
          <button class="timeline__nav-item" type="button" aria-current="false">
            <span class="sr-only">Ir al hito 6</span>
            <span class="timeline__nav-label text-sm bold">Hoy</span>
          </button>
        </page-dots>
      </div>

      <div aria-controls="timeline-carousel-armsmusic" class="timeline__buttons md-max:hidden">
        <button is="prev-button" class="circle-button ring group" aria-controls="timeline-carousel-armsmusic">
          <span class="sr-only">Anterior</span>
          <span class="animated-arrow animated-arrow--reverse"></span>
        </button>

        <button is="next-button" class="circle-button ring group" aria-controls="timeline-carousel-armsmusic">
          <span class="sr-only">Siguiente</span>
          <span class="animated-arrow"></span>
        </button>
      </div>
    </div>

  </div>
</div>
